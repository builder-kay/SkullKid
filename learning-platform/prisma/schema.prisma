generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum SubjectCode {
  MATHEMATICS
  ENGLISH
  SCIENCE
}

enum RecommendationType {
  NEXT_LESSON
  PRACTICE
  REMEDIAL
}

model User {
  id            String            @id @default(cuid())
  fullName      String
  email         String            @unique
  passwordHash  String
  role          Role
  classroomId   String?
  avatarUrl     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  student       StudentProfile?
  teacher       TeacherProfile?
  classroom     Classroom?        @relation(fields: [classroomId], references: [id])
  lessonProgress ProgressRecord[]
  quizAttempts  QuizAttempt[]
  feedbackSent  FeedbackMessage[] @relation("FeedbackSender")
  feedbackRecv  FeedbackMessage[] @relation("FeedbackRecipient")
  recommendations Recommendation[]
}

model StudentProfile {
  id             String         @id @default(cuid())
  userId         String         @unique
  xp             Int            @default(0)
  level          String         @default("Explorer")
  streakDays     Int            @default(0)
  lastActiveDate DateTime?
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  badges         StudentBadge[]
}

model TeacherProfile {
  id      String @id @default(cuid())
  userId  String @unique
  bio     String?
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Classroom {
  id        String   @id @default(cuid())
  name      String
  grade     Int
  createdAt DateTime @default(now())
  students  User[]
  subjects  Subject[]
}

model Subject {
  id          String      @id @default(cuid())
  code        SubjectCode @unique
  title       String
  description String?
  classroomId String?
  classroom   Classroom?  @relation(fields: [classroomId], references: [id])
  lessons     Lesson[]
  leaderboard LeaderboardSnapshot[]
}

model Lesson {
  id          String           @id @default(cuid())
  subjectId   String
  title       String
  description String
  content     String
  difficulty  Int              @default(1)
  orderIndex  Int
  createdById String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  subject     Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  quiz        Quiz?
  progress    ProgressRecord[]
}

model Quiz {
  id          String         @id @default(cuid())
  lessonId    String         @unique
  title       String
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  lesson      Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions   QuizQuestion[]
  attempts    QuizAttempt[]
}

model QuizQuestion {
  id            String   @id @default(cuid())
  quizId         String
  prompt         String
  options        Json
  correctAnswer  String
  explanation    String?
  difficulty     Int      @default(1)
  topicTag       String
  orderIndex     Int
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionLogs   QuestionAttempt[]
}

model QuizAttempt {
  id            String           @id @default(cuid())
  userId        String
  quizId        String
  score         Int
  totalQuestions Int
  correctCount  Int
  durationSec   Int?
  createdAt     DateTime         @default(now())
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz          Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionLogs  QuestionAttempt[]
}

model QuestionAttempt {
  id             String      @id @default(cuid())
  attemptId      String
  questionId     String
  selectedAnswer String
  isCorrect      Boolean
  attempt        QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model ProgressRecord {
  id           String   @id @default(cuid())
  userId       String
  lessonId     String
  completion   Float    @default(0)
  bestScore    Int      @default(0)
  attempts     Int      @default(0)
  weakTopics   String[]
  consistency  Float    @default(0)
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Badge {
  id          String        @id @default(cuid())
  name        String        @unique
  description String
  icon        String
  awardedTo   StudentBadge[]
}

model StudentBadge {
  id        String         @id @default(cuid())
  studentId String
  badgeId   String
  awardedAt DateTime       @default(now())
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  badge     Badge          @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([studentId, badgeId])
}

model LeaderboardSnapshot {
  id          String   @id @default(cuid())
  classroomId String
  subjectId   String
  userId      String
  xp          Int
  score       Int
  rank        Int
  period      String
  createdAt   DateTime @default(now())
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model Recommendation {
  id          String              @id @default(cuid())
  userId      String
  lessonId    String?
  type        RecommendationType
  reason      String
  isCompleted Boolean             @default(false)
  createdAt   DateTime            @default(now())
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeedbackMessage {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  message     String
  createdAt   DateTime @default(now())
  sender      User     @relation("FeedbackSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User     @relation("FeedbackRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
}
